# prefixes for SI units:

prefix Y := 1e24: real;
prefix Z := 1e21: real;
prefix E := 1e18: real;
prefix P := 1e15: real;
prefix T := 1e12: real;
prefix G := 1e9: real;
prefix M := 1e6: real;
prefix k := 1e3: real;
prefix h := 1e2: real;
prefix da := 10: real;
prefix d := 1e-1: real;
prefix c := 1e-2: real;
prefix m := 1e-3: real;
prefix u := 1e-6: real;
prefix n := 1e-9: real;
prefix p := 1e-12: real;
prefix f := 1e-15: real;
prefix a := 1e-18: real;
prefix z := 1e-21: real;
prefix y := 1e-24: real;

